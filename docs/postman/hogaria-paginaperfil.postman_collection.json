            "description": "Comprobar 200 y array de reservas."
          }
        },
        {
          "name": "POST /api/user/bookings",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"service_name\": \"Limpieza integral\",\n  \"description\": \"Piso de 90m2\",\n  \"date\": \"2026-03-20\",\n  \"price\": 85\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/user/bookings?user_id={{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "bookings"],
              "query": [{ "key": "user_id", "value": "{{userId}}" }]
            },
            "description": "Comprobar 201 y guardar id de la reserva para pruebas posteriores."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const data = pm.response.json();",
                  "if (data.id) pm.collectionVariables.set('bookingId', String(data.id));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/user/bookings/:booking_id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/user/bookings/{{bookingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "bookings", "{{bookingId}}"]
            },
            "description": "Comprobar 200 si existe; 404 si no."
          }
        },
        {
          "name": "PUT /api/user/bookings/:booking_id",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"service_name\": \"Limpieza premium\",\n  \"description\": \"Con ventanas\",\n  \"date\": \"2026-03-22\",\n  \"price\": 99,\n  \"status\": \"confirmed\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/user/bookings/{{bookingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "bookings", "{{bookingId}}"]
            },
            "description": "Comprobar 200 y estado actualizado. Estados válidos: pending, confirmed, completed, cancelled."
          }
        },
        {
          "name": "DELETE /api/user/bookings/:booking_id",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/user/bookings/{{bookingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "bookings", "{{bookingId}}"]
            },
            "description": "Comprobar 200 y mensaje de cancelación. Luego verificar con GET que la reserva queda en estado cancelled."
          }
        }
      ]
    },
